
# =============================================================================
# Metering Server (REST API АИИС КУЭ)
# =============================================================================
METERING_BASE_URL=http://metering.local:8080
METERING_USER=
METERING_PASS=

# =============================================================================
# HelpDeskEddy API v2 (https://helpdeskeddy.ru/api.html)
# =============================================================================
# Хост без /api/v2 — префикс добавляет клиент.
HELPDESK_EDDY_BASE_URL=https://support.lar.tech
# Аутентификация Basic: base64(email:api_key).
# email — учётка пользователя HDE; api_key — из его профиля.
HELPDESK_EDDY_EMAIL=operator@example.com
HELPDESK_EDDY_API_KEY=
# Ссылка на тикет в сообщении оператору ({id} = номер тикета).
HELPDESK_TICKET_URL_TEMPLATE=https://support.lar.tech/ru/ticket/list/filter/id/1/ticket/{id}

# =============================================================================
# Поведение агента
# =============================================================================
# Максимум ПУ в одной массовой операции (защита от перегрузки Metering Server).
MAX_BULK_SIZE=50
# Каталог для генерируемых отчётов (xlsx/png-вложений).
REPORTS_DIR=./reports

# =============================================================================
# RAG: LLM-провайдер и векторное хранилище
# =============================================================================
# Провайдер генерации в RAG: deepseek | ollama.
LLM_PROVIDER=deepseek
# DeepSeek (OpenAI-совместимый эндпоинт)
DEEPSEEK_BASE_URL=http://chatbot.lar.tech:8080/v1
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
# 0.2 — почти детерминированно (дословные команды/пароли из базы), но чуть живее
# формулировки. Предполагаемые инструкции обеспечивает промпт, а не температура.
DEEPSEEK_TEMPERATURE=0.2
DEEPSEEK_TIMEOUT=300
# "minimal" — быстрый ответ без длинных рассуждений; "none" — отключить рассуждения.
DEEPSEEK_REASONING_EFFORT=minimal
# Ollama (резервный провайдер)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=qwen3:4b-instruct
OLLAMA_TEMPERATURE=0
OLLAMA_TIMEOUT=120

# Qdrant — три формы QDRANT_URL:
#   ./data/qdrant         — встроенное ФАЙЛОВОЕ хранилище (рекомендуется): сервер
#                           НЕ нужен, движок входит в пакет qdrant-client. Один
#                           процесс за раз (файловая блокировка): сначала
#                           `python -m rag.index`, потом запуск приложения.
#   http://localhost:6333 — внешний сервер Qdrant (Docker/brew). Нужен, если хотите
#                           индексировать без остановки сервиса. QDRANT_API_KEY — для него.
#   :memory:              — в памяти, без персистентности (только для тестов).
QDRANT_URL=./data/qdrant
QDRANT_API_KEY=
QDRANT_COLLECTION=metering_kb
# Мультиязычная эмбеддинг-модель (fastembed) — нужна для русского текста.
EMBED_MODEL=intfloat/multilingual-e5-large
KB_DIR=./knowledge_base
RAG_TOP_K=6
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200
# Куда fastembed кладёт модели (читает сама библиотека). Удобно вынести с C:.
FASTEMBED_CACHE_PATH=./models

# =============================================================================
# Telegram-бот (human-in-the-loop ревью тикетов)
# =============================================================================
# Токен бота от @BotFather.
TELEGRAM_BOT_TOKEN=
# ID группового чата для рассылки тикетов (например, -1001234567890).
TELEGRAM_CHAT_ID=
TELEGRAM_API_BASE=https://api.telegram.org
# Прокси ТОЛЬКО для Telegram (socks5://user:pass@host:port или http://...).
# Заполнять, если api.telegram.org заблокирован у провайдера/хостинга. Пусто = без прокси.
TELEGRAM_PROXY=
TELEGRAM_POLL_TIMEOUT=30
# Белый список тех, кому можно управлять ботом (кнопки и команды).
# Через запятую: numeric user_id и/или @username. ПУСТО = разрешено всем.
# Пример: TELEGRAM_ALLOWED_USERS=123456789, @a_semenov, 987654321
TELEGRAM_ALLOWED_USERS=

# =============================================================================
# Датасет решений операторов и ручная подтяжка тикетов
# =============================================================================
# SQLite с решениями операторов (датасет для дообучения).
FEEDBACK_DB=./data/feedback.sqlite3
# Ручная подтяжка тикетов командой /fetch и автоопрос поллером.
FETCH_STATUSES=open
FETCH_LIMIT=10
# Интервал автоопроса HelpDesk поллером (секунды). 1200 = 20 минут.
# Поллер сам тянет новые тикеты (только GET) и шлёт на ревью — замена webhook
# для случая, когда до нашего хоста не достучаться извне (Mac за NAT/VPN).
POLL_INTERVAL=1200
