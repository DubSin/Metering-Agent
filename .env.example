# =============================================================================
# ER-GPT (LLM, нативный API v2)
# =============================================================================
# Ключ ER-GPT. Если не задан, используется OPENAI_API_KEY (legacy fallback).
ERGPT_API_KEY=
# Базовый URL ER-GPT-портала (внутренний контур).
ERGPT_BASE_URL=https://chatbot.lar.tech
# Имя модели в ER-GPT. Если не задано — берётся OPENAI_MODEL.
ERGPT_MODEL=ERGPT-Main
# Таймаут запроса к LLM в секундах.
ERGPT_TIMEOUT=120
# ID базы знаний ER-GPT для RAG. Пусто = RAG отключён (LLM без kb_id).
ERGPT_KB_ID=

# Legacy fallback (на случай если ERGPT_* не заданы)
OPENAI_API_KEY=
OPENAI_MODEL=

# =============================================================================
# Metering Server (REST API АИИС КУЭ)
# =============================================================================
METERING_BASE_URL=http://metering.local:8080
METERING_USER=
METERING_PASS=

# =============================================================================
# HelpDeskEddy API v2 (https://helpdeskeddy.ru/api.html)
# =============================================================================
# Хост без /api/v2 — префикс добавляет клиент.
HELPDESK_EDDY_BASE_URL=https://support.lar.tech
# Аутентификация Basic: base64(email:api_key).
# email — учётка пользователя HDE; api_key — из его профиля.
HELPDESK_EDDY_EMAIL=
HELPDESK_EDDY_API_KEY=
# Опц. секрет HMAC для проверки исходящих webhook'ов (заголовок X-HelpDesk-Signature).
# Пусто = проверка подписи отключена.
HELPDESK_EDDY_WEBHOOK_SECRET=
# Канал ответа агента: "comments" (внутренний, видят только сотрудники)
# или "posts" (публичный, видит клиент). По проектному решению — comments.
HELPDESK_EDDY_REPLY_CHANNEL=comments
# Статус, в который переводим тикет после успешного ответа. Пусто = не менять.
# Возможные значения HDE: open / process / closed.
HELPDESK_EDDY_POST_REPLY_STATUS=process
# Фильтр статусов поллера (через запятую). По умолчанию — только новые.
HELPDESK_EDDY_POLL_STATUSES=open
# Таймаут HTTP-запросов к HDE в секундах. Лимит HDE: 300 RPM, 20 мин блокировки.
HELPDESK_EDDY_TIMEOUT=30

# =============================================================================
# Поллер HelpDeskEddy (страховка на случай пропущенного webhook)
# =============================================================================
# Интервал опроса HDE в секундах.
POLL_INTERVAL_SECONDS=60
# Путь к файлу с ID обработанных тикетов (файловый дедуп).
PROCESSED_TICKETS_PATH=./state/processed_tickets.txt
# Путь к файлу с курсором поллера (последний обработанный date_created в формате HDE).
POLL_CURSOR_PATH=./state/poll_cursor.txt

# =============================================================================
# Поведение агента
# =============================================================================
# Максимум ПУ в одной массовой операции (защита от перегрузки Metering Server).
MAX_BULK_SIZE=50
# Каталог для генерируемых отчётов (xlsx/png-вложений).
REPORTS_DIR=./reports
