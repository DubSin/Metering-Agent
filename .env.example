# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Metering Server (REST)
METERING_BASE_URL=http://metering.local:8080
METERING_USER=
METERING_PASS=

# HelpDeskEddy (единая система поддержки, в пайплайне только GET)
HELPDESK_EDDY_BASE_URL=https://support.lar.tech/ru
HELPDESK_EDDY_API_KEY=
# Email оператора для Basic-аутентификации API v2 (email:api_key)
HELPDESK_EDDY_EMAIL=
# Шаблон ссылки на тикет в сообщении оператору ({id} = номер тикета)
HELPDESK_TICKET_URL_TEMPLATE=https://support.lar.tech/ru/ticket/list/filter/id/1/ticket/{id}

# Telegram-бот (human-in-the-loop ревью)
TELEGRAM_BOT_TOKEN=
# ID группового чата (например, -1001234567890)
TELEGRAM_CHAT_ID=
TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_POLL_TIMEOUT=30
# Белый список управляющих ботом (кнопки/команды). Через запятую: user_id и/или @username.
# ПУСТО = разрешено всем. Пример: 123456789, @a_semenov
TELEGRAM_ALLOWED_USERS=

# Поведение
MAX_BULK_SIZE=50
REPORTS_DIR=./reports
# SQLite с решениями операторов (датасет для дообучения)
FEEDBACK_DB=./data/feedback.sqlite3

# Ручная подтяжка тикетов командой бота /fetch
FETCH_STATUSES=open
FETCH_LIMIT=20

# Провайдер LLM для генерации в RAG: deepseek | ollama
LLM_PROVIDER=deepseek

# DeepSeek (OpenAI-совместимый сервер: домен:порт + /v1)
DEEPSEEK_BASE_URL=http://chatbot.lar.tech:8081/v1
DEEPSEEK_API_KEY=
# Пусто → возьмём первую модель из GET /v1/models
DEEPSEEK_MODEL=
DEEPSEEK_TEMPERATURE=0.2
DEEPSEEK_TIMEOUT=120

# Ollama (OpenAI-совместимый эндпоинт: host:11434 + /v1)
# Активен, когда LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
# Пусто → возьмём первую модель из GET /v1/models (напр. llama3.1, qwen2.5)
OLLAMA_MODEL=
OLLAMA_TEMPERATURE=0.2
OLLAMA_TIMEOUT=120

# RAG / Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=metering_kb
# Мультиязычная эмбеддинг-модель (fastembed), нужна для русского текста
EMBED_MODEL=intfloat/multilingual-e5-large
KB_DIR=./knowledge_base
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=6
